{
  "compileOnSave": false,
  "files": [],
  "references": [
    { "path": "./src/tsconfig.app.json" },
    { "path": "./src/tsconfig.spec.json" }
  ],
  "compilerOptions": {
    "importHelpers": true,
    "esModuleInterop": true,
    "module": "es2020",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "experimentalDecorators": true,
    "target": "ES2022",
    "typeRoots": [
      "node_modules/@types"
    ],
    "strict": true,
    "skipLibCheck": true,
    "useDefineForClassFields": false
  }
}
